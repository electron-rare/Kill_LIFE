      "y": 150,
      "runner": {
        "kind": "local-action",
        "action": "evidence.verify"
      },
      "config": {
        "target": "esp"
      }
    },
    {
      "id": "collect-linux",
      "type": "local-action",
      "label": "Collect Native Evidence",

      "x": 860,
      "y": 360,
      "runner": {
        "kind": "local-action",
        "action": "evidence.collect"
      },
      "config": {
        "target": "linux"
      }
    },
    {
      "id": "verify-linux",
      "type": "local-action",
      "label": "Verify Native Evidence",
      "description": "Confirm that the native evidence pack exists and is valid.",
      "x": 1160,
      "y": 360,
      "runner": {
        "kind": "local-action",
        "action": "evidence.verify"
      },
      "config": {
        "target": "linux"
      }

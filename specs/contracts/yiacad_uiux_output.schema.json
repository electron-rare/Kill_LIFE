{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electron-rare.local/specs/contracts/yiacad_uiux_output.schema.json",
  "title": "YiACAD UI UX Output Contract",
  "type": "object",
  "required": [
    "component",
    "surface",
    "action",
    "execution_mode",
    "status",
    "severity",
    "summary",
    "degraded_reasons",
    "engine_status",
    "artifacts",
    "next_steps"
  ],
  "properties": {
    "component": {
      "type": "string",
      "const": "yiacad"
    },
    "surface": {
      "type": "string",
      "description": "YiACAD client surface identifier, e.g. yiacad-desktop, yiacad-web, yiacad-api, tui"
    },
    "action": {
      "type": "string"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "interactive",
        "batch",
        "background"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "done",
        "degraded",
        "blocked"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "info",
        "warning",
        "error"
      ]
    },
    "summary": {
      "type": "string"
    },
    "details": {
      "type": [
        "string",
        "null"
      ]
    },
    "generated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "context_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider": {
      "type": [
        "string",
        "null"
      ]
    },
    "model": {
      "type": [
        "string",
        "null"
      ]
    },
    "latency_ms": {
      "type": [
        "integer",
        "null"
      ]
    },
    "degraded_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "engine_status": {
      "type": "object",
      "properties": {
        "kicad": {
          "$ref": "#/$defs/engineEntry"
        },
        "freecad": {
          "$ref": "#/$defs/engineEntry"
        },
        "kibot": {
          "$ref": "#/$defs/engineEntry"
        },
        "kiauto": {
          "$ref": "#/$defs/engineEntry"
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "path"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "report",
              "log",
              "export",
              "evidence"
            ]
          },
          "path": {
            "type": "string"
          },
          "label": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "engineEntry": {
      "type": "object",
      "required": [
        "name",
        "integrated",
        "binary",
        "required_version",
        "detected_version",
        "available",
        "status",
        "reason"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "integrated": {
          "type": "boolean"
        },
        "binary": {
          "type": [
            "string",
            "null"
          ]
        },
        "required_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "detected_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "done",
            "degraded",
            "blocked"
          ]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
